ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173"]
# Supabase: copy the connection string from Project Settings → Database.
# Replace `postgresql://` with `postgresql+asyncpg://` for the async driver.
DATABASE_URL=postgresql+asyncpg://localhost/shmuel

# Fernet key for encrypting OAuth refresh tokens.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Google OAuth — Google Cloud → APIs & Services → Credentials → "OAuth 2.0 Client IDs" (Web application)
# Authorized redirect URI must match GOOGLE_OAUTH_REDIRECT_URI exactly.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
ADMIN_REDIRECT_URI=http://localhost:5173/settings

# Optional — leave empty in dev. Get the DSN from sentry.io after creating
# a "Python (FastAPI)" project. Errors are forwarded to Sentry only when set.
SENTRY_DSN=
