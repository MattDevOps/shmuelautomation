ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173"]
# Supabase: copy the connection string from Project Settings → Database.
# Replace `postgresql://` with `postgresql+asyncpg://` for the async driver.
DATABASE_URL=postgresql+asyncpg://localhost/shmuel

# Fernet key for encrypting OAuth refresh tokens.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Google OAuth — Google Cloud → APIs & Services → Credentials → "OAuth 2.0 Client IDs" (Web application)
# Authorized redirect URI must match GOOGLE_OAUTH_REDIRECT_URI exactly.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
ADMIN_REDIRECT_URI=http://localhost:5173/settings

# Optional — leave empty in dev. Get the DSN from sentry.io after creating
# a "Python (FastAPI)" project. Errors are forwarded to Sentry only when set.
SENTRY_DSN=

# Resend transactional email — newsletter confirmation + digest emails.
# Empty = no-op (signups still record into the DB; no email goes out).
# Without a verified domain, Resend only sends from onboarding@resend.dev
# and only to the address that owns the Resend account.
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=Classic Jerusalem Realty <newsletter@classicjerusalem.com>
NEWSLETTER_API_BASE_URL=http://localhost:8000
NEWSLETTER_SITE_BASE_URL=https://classicjerusalem.com
NEWSLETTER_DIGEST_THRESHOLD=3

# OpenAI for content translation (ES/FR/HE) of properties, blog posts,
# and neighborhoods. Empty = no-op (sync logs would-be calls, writes nothing).
OPENAI_API_KEY=
OPENAI_TRANSLATE_MODEL=gpt-4o-mini

# WP REST base used by the translation sync to source content. Override only
# if WP is staged elsewhere.
WP_REST_BASE=https://realestateadmin2025.classicjerusalem.com/wp-json/wp/v2

# whatsapp-daemon — the self-hosted Baileys daemon in `whatsapp-daemon/`.
# Both vars must be set for /whatsapp/status to flip to reachable=true and
# for auto_poster to dispatch. Empty = no-op (calls log "would have sent…"
# and return None). Generate the token with `openssl rand -hex 32` and
# configure the same value on the daemon side.
WHATSAPP_DAEMON_URL=
WHATSAPP_DAEMON_TOKEN=
