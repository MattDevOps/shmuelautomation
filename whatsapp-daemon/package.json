{
  "name": "shmuel-whatsapp-daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Long-running Baileys daemon for Classic Jerusalem Realty. Pairs to a dedicated 2nd WhatsApp number, exposes a small HTTP API for the FastAPI backend, and forwards inbound messages to the backend webhook.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.18",
    "express": "^4.21.2",
    "pino": "^9.7.0",
    "qrcode": "^1.5.4",
    "undici": "^7.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
