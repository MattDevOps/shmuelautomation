# Port the HTTP API listens on. Fly.io and Cloud Run override this.
PORT=8787

# Shared secret. The FastAPI backend sends this as `X-Daemon-Token` on every
# call into the daemon; the daemon sends this as `X-Daemon-Token` on every
# call into the backend's /webhooks/whatsapp/* routes. Generate via
# `openssl rand -hex 32`.
DAEMON_AUTH_TOKEN=

# Base URL the daemon calls to (a) load/save the auth blob and (b) push
# inbound messages. e.g. https://api.classicjerusalem.com  (prod) or
# http://127.0.0.1:8080  (local dev). No trailing slash.
BACKEND_BASE_URL=http://127.0.0.1:8080

# Backend's own API key (the X-API-Key header it expects on its non-/public
# routes). The daemon uses this in addition to X-Daemon-Token because the
# backend's general middleware enforces X-API-Key for /whatsapp/*.
BACKEND_API_KEY=

# Optional: pino log level. info | debug | trace
LOG_LEVEL=info
